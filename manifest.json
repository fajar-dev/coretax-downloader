{
  "manifest_version": 3,
  "name": "Coretax Bupot Sync",
  "version": "3.5",
  "description": "Synchronize dokumen Bukti Potong PPh dari Coretax ke IS",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "downloads", "identity"],
  "host_permissions": [
    "https://coretaxdjp.pajak.go.id/*",
    "https://www.googleapis.com/*",
    "https://transit.is5x.nusa.net.id/*"
  ],
  "oauth2": {
    "client_id": "1028176199908-td4hg9bljqijr8rtr5ir1hbjegrkg2mi.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  }
}
